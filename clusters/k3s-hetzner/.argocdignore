# Helm values files are not Kubernetes manifests
**/values.yaml

# Kustomize config files are not Kubernetes manifests
**/kustomization.yaml
**/kustomization.yml

# Don't let cluster-root apply Kyverno policies (handled by kyverno-policies app)
**/kyverno/policies/*.yaml
**/kyverno/policies/**/*.yaml


# Exclude Kyverno ClusterPolicies from cluster-root (owned by kyverno-policies)
kyverno/policies/disallow-latest-tag.yaml
kyverno/policies/require-probes.yaml
